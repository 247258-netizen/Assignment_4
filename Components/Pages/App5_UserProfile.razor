@page "/profile"
@rendermode InteractiveServer
@inject AuthenticationStateService AuthService
@implements IDisposable

<PageTitle>App 5 - User Profile</PageTitle>

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-dark text-white">
            <h3>Application 5: State Management – User Profile</h3>
        </div>
        <div class="card-body">
            @if (AuthService.IsAuthenticated)
            {
                <div class="text-center py-4">
                    <div class="display-1">👤</div>
                    <h2 class="mt-3">Welcome, <span class="text-success">@AuthService.UserName</span>!</h2>
                    <p><strong>Status:</strong> <span class="badge bg-success">Authenticated</span></p>
                    <button class="btn btn-warning mt-3" @onclick="AuthService.LogOut">Log Out</button>
                </div>
            }
            else
            {
                <div class="text-center py-4">
                    <div class="display-1">🔒</div>
                    <h4 class="mt-3 text-danger">Access Denied</h4>
                    <a class="btn btn-dark mt-2" href="/login">Go to Login</a>
                </div>
            }
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized() => AuthService.OnChange += StateHasChanged;
    public void Dispose() => AuthService.OnChange -= StateHasChanged;
}
