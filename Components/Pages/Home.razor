@page "/"
<PageTitle>Blazor Apps - Assignment 4</PageTitle>
<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header text-white" style="background: linear-gradient(135deg, rgb(5,39,103), #3a0647);">
            <h3 class="mb-0">Assignment 4 — Blazor Applications</h3>
        </div>
        <div class="card-body">
            <p class="text-muted mb-4">Select any app from the left sidebar to open it.</p>
            <div class="row g-3">
                <div class="col-md-6"><a href="/greeting" class="text-decoration-none"><div class="card border-primary h-100"><div class="card-body"><h6 class="text-primary">App 1 — Greeting Component</h6><small class="text-muted">One-way and two-way data binding</small></div></div></a></div>
                <div class="col-md-6"><a href="/register" class="text-decoration-none"><div class="card border-success h-100"><div class="card-body"><h6 class="text-success">App 2 — Form Validation</h6><small class="text-muted">EditForm with DataAnnotationsValidator</small></div></div></a></div>
                <div class="col-md-6"><a href="/todo" class="text-decoration-none"><div class="card border-warning h-100"><div class="card-body"><h6 class="text-warning">App 3 — To-Do List</h6><small class="text-muted">Dynamic list with add/remove</small></div></div></a></div>
                <div class="col-md-6"><a href="/counter-app" class="text-decoration-none"><div class="card border-info h-100"><div class="card-body"><h6 class="text-info">App 4 — Click Counter</h6><small class="text-muted">Event handling with onclick</small></div></div></a></div>
                <div class="col-md-6"><a href="/login" class="text-decoration-none"><div class="card border-dark h-100"><div class="card-body"><h6>App 5 — Auth State Service</h6><small class="text-muted">Singleton service for login state</small></div></div></a></div>
                <div class="col-md-6"><a href="/notification-settings" class="text-decoration-none"><div class="card border-secondary h-100"><div class="card-body"><h6 class="text-secondary">App 6 — Notification Service</h6><small class="text-muted">Configurable DI service</small></div></div></a></div>
                <div class="col-md-6"><a href="/theme" class="text-decoration-none"><div class="card h-100" style="border-color:#374151;"><div class="card-body"><h6 style="color:#374151;">App 7 — Theme Toggle</h6><small class="text-muted">Light/Dark mode with localStorage</small></div></div></a></div>
                <div class="col-md-6"><a href="/todo-db" class="text-decoration-none"><div class="card border-danger h-100"><div class="card-body"><h6 class="text-danger">App 8 — ToDo Database</h6><small class="text-muted">Full CRUD with EF Core + SQLite</small></div></div></a></div>
            </div>
        </div>
    </div>
</div>
